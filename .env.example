# Environment Configuration
# Copy this file to .env and fill in your actual values

# Server Configuration
NODE_ENV=development
PORT=5000

# CORS Configuration
# Add your allowed origins (comma-separated for multiple domains)
CORS_ORIGIN=http://localhost:3000,http://localhost:5000

# Firebase Configuration
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=h2go-eee4d
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@h2go-eee4d.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://h2go-eee4d-default-rtdb.asia-southeast1.firebasedatabase.app

# Firebase Web API Key
# Get this from Firebase Console > Project Settings > General > Web API Key
FIREBASE_API_KEY=your_firebase_web_api_key_here

# JWT Secret (if using JWT tokens)
JWT_SECRET=your_jwt_secret_key_here

# Standard temporary password for newly added staff
DEFAULT_TEMP_PASSWORD=H2GO@123

# SMTP Configuration for Email Notifications
# Gmail example (use App Passwords for Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=frightfullpoll@gmail.com
SMTP_PASS=FRIGHTFULLPOLL
SMTP_FROM=frightfullpoll@gmail.com

# OTP Configuration for user verification
OTP_EXPIRY_MINUTES=10
OTP_PEPPER=your_random_otp_pepper_here

# Optional: Logging and Monitoring
LOG_LEVEL=info

# Optional: External Services (for future implementation)
# Payment Integration (PayMongo)
PAYMONGO_SECRET_KEY=your_paymongo_secret_key
PAYMONGO_PUBLIC_KEY=your_paymongo_public_key

# Email Service (for notifications)
EMAIL_SERVICE=gmail
EMAIL_USER=frightfullpoll@gmail.com
EMAIL_PASS=FRIGHTFULLPOLL

# Push Notifications (FCM)
FCM_SERVER_KEY=your_fcm_server_key
